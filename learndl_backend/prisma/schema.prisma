generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  userId           String            @id @default(uuid()) @db.Uuid @map("user_id")
  name             String?
  email            String            @unique
  firebaseUid      String            @map("firebase_uid")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  datasets         Dataset[]
  trainingSessions TrainingSession[]

  @@map("users")
}

model TrainingSession {
  sessionId   String   @id @default(uuid()) @db.Uuid @map("session_id")
  userId      String   @db.Uuid @map("user_id")
  datasetId   String   @db.Uuid @map("dataset_id")
  modelName   String   @map("model_name")
  hyperParams Json?    @map("hyper_params")
  metrics     Json?
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [userId], onDelete: Cascade)
  dataset     Dataset  @relation(fields: [datasetId], references: [datasetId], onDelete: Cascade)

  @@map("training_sessions")
}

model Dataset {
  datasetId         String             @id @default(uuid()) @db.Uuid @map("dataset_id")
  userId            String             @db.Uuid @map("user_id")
  csvName           String             @map("csv_name")
  sessionId         String?            @db.Uuid @map("session_id")
  createdAt         DateTime           @default(now()) @map("created_at")
  user              User               @relation(fields: [userId], references: [userId], onDelete: Cascade)
  trainingSessions  TrainingSession[]

  @@map("datasets")
}
